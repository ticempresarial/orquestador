# Telegram
# Token del bot, obtener de @BotFather con /newbot
TELEGRAM_BOT_TOKEN=

# IDs autorizados (coma-separados). Tu id lo obtienes de @userinfobot.
# Cualquier user_id fuera de esta lista será ignorado.
ALLOWED_TELEGRAM_USER_IDS=

# Claude Code CLI
# Directorio donde Claude trabajará (debe existir, contiene los repos team-*).
CLAUDE_WORKDIR=/Users/datacole/orquestador

# Path al binario de Claude. Cambiar si está en otra ruta.
CLAUDE_BIN=claude

# Timeout en segundos para una invocación de Claude. Default 300 (5 min).
CLAUDE_TIMEOUT_SECONDS=300

# Carpeta donde se guardan los proyectos del intake (Fase 1+).
# Default: ~/proyectos
PROYECTOS_DIR=/Users/datacole/proyectos

# Archivo de estado de sesiones (Fase 1+).
# Default: telegram-bot/state/sessions.json (relativo al bot)
# STATE_FILE=/Users/datacole/orquestador/orquestador/telegram-bot/state/sessions.json
